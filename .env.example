# ══════════════════════════════════════════════════════════════════
#  Arab tili — barcha loyiha uchun maxfiy sozlamalar SHABLONI
#  Bu faylni ".env.local" nomi bilan ko'chirib, qiymatlarni to'ldiring
#  .env.example → git ga yuklanadi (shablon)
#  .env.local   → git ga YUKLANMAYDI (haqiqiy qiymatlar)
# ══════════════════════════════════════════════════════════════════

# ── Vite / Web frontend ────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com
VITE_PHP_GOOGLE_AUTH_URL=http://your-server.com/arab.php
VITE_PHP_GOOGLE_AUTH_FIELD=access_token

# ── Flutter app ────────────────────────────────────────────────────
# (flutter_app/.env faylida saqlang)
PHP_BASE_URL=http://your-server.com/arab.php
FIREBASE_API_KEY=your_firebase_api_key
GOOGLE_SERVER_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com

# ── Node.js backend (google auth/) ────────────────────────────────
# (google auth/.env faylida saqlang)
NODE_ENV=development
PORT=3000
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=google_auth
DATABASE_USER=postgres
DATABASE_PASSWORD=your_db_password_here
DATABASE_SSL=false
TYPEORM_SYNC=true
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
JWT_SECRET=your_very_long_random_secret_key_here
JWT_EXPIRES_IN=15m
