/// SHABLON — bu faylni "app_secrets.dart" nomi bilan ko'chirib,
/// qiymatlarni to'ldiring. app_secrets.dart .gitignore da!
///
/// Ko'chirish:
///   cp lib/config/app_secrets.dart.example lib/config/app_secrets.dart

// ignore_for_file: constant_identifier_names

class AppSecrets {
  AppSecrets._();

  /// PHP backend URL
  static const String phpBaseUrl = String.fromEnvironment(
    'PHP_BASE_URL',
    defaultValue: 'http://your-server.com/arab.php',
  );

  /// Firebase REST API key (google-services.json → current_key)
  static const String firebaseApiKey = String.fromEnvironment(
    'FIREBASE_API_KEY',
    defaultValue: 'YOUR_FIREBASE_API_KEY',
  );

  /// Google Web Client ID (serverClientId — idToken uchun)
  static const String googleServerClientId = String.fromEnvironment(
    'GOOGLE_SERVER_CLIENT_ID',
    defaultValue: 'YOUR_WEB_CLIENT_ID.apps.googleusercontent.com',
  );
}
